<?xml version="1.0" encoding="UTF-8" ?>
<!DOCTYPE mapper
PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN"
"http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="UserExtraMapper">
	
	<cache eviction="LRU" flushInterval="0" size="50" />
	
	<resultMap id="userExtraResult" type="UserExtraEntity" uniqueColumn="id" autoMapping="true" />
	
	<sql id="userExtraVo">
		select * from user_extra
	</sql>
	
	<select id="select_user_extra_by_id" resultMap="userExtraResult" databaseId="Test">
		<include refid="userExtraVo"/>
		where id == #{id}
	</select>
	
	<select id="select_user_extra" resultMap="userExtraResult" databaseId="Test">
		<include refid="userExtraVo"/>
		<where>
			<if test="id != null">and id == #{id}</if>
			<if test="title != null">and title == #{title}</if>
			<if test="location != null">and location == #{location}</if>
		</where>
	</select>
	
	<select id="select_user_extra_list" resultMap="userExtraResult" databaseId="Test">
		<include refid="userExtraVo"/>
		<where>
			<if test="id != null">and id == #{id}</if>
			<if test="title != null">and title == #{title}</if>
			<if test="location != null">and location == #{location}</if>
		</where>
	</select>
	
	<update id="update_user_extra" databaseId="Test">
		update user_extra
		<set>
			<if test="id != null">id = #{id},</if>
			<if test="title != null">title = #{title},</if>
			<if test="location != null">location = #{location},</if>
		</set>
		where id == #{id}
	</update>
	
	<insert id="insert_user_extra" databaseId="Test">
		insert into user_extra(
			<trim suffixOverrides=",">
				<if test="id != null">id,</if>
				<if test="title != null">title,</if>
				<if test="location != null">location,</if>
			</trim>
		)values(
			<trim suffixOverrides=",">
				<if test="id != null">#{id},</if>
				<if test="title != null">#{title},</if>
				<if test="location != null">#{location},</if>
			</trim>
		)
	</insert>
	
	<delete id="delete_user_extra_by_id" databaseId="Test">
		delete from user_extra where id == #{id}
	</delete>
	
</mapper>
