#!/bin/bash
## Git pre-push hook: auto-update file_manifest.txt before pushing a tag.

MANIFEST="addons/gdsql/tabs/plugin_updater/file_manifest.txt"
CHANGED=0

while read local_ref local_sha remote_ref remote_sha; do
	if [[ "$local_ref" == refs/tags/v* ]]; then
		TAG="${local_ref#refs/tags/}"
		VER="${TAG#v}"

		TAG_MSG=$(git tag -l --format='%(contents)' "$TAG" 2>/dev/null)

		PREV_TAG=$(git tag --sort=-version:refname | grep -E '^v' | sed -n '2p')

		if [ -n "$PREV_TAG" ]; then
			echo "Diffing $PREV_TAG → $TAG"

			grep -v "^[+-],$VER," "$MANIFEST" > "${MANIFEST}.tmp" 2>/dev/null && mv "${MANIFEST}.tmp" "$MANIFEST"

			while IFS= read -r f; do
				f="${f//\"/}"
				[ -n "$f" ] && echo "+,$VER,$f" >> "$MANIFEST"
			done < <(git diff --name-only --diff-filter=A "$PREV_TAG"...HEAD -- addons/gdsql/ | grep -v '\.translation$')
			while IFS= read -r f; do
				f="${f//\"/}"
				[ -n "$f" ] && echo "-,$VER,$f" >> "$MANIFEST"
			done < <(git diff --name-only --diff-filter=D "$PREV_TAG"...HEAD -- addons/gdsql/ | grep -v '\.translation$')
		else
			echo "No previous tag. Creating initial manifest."
			find addons/gdsql/ -type f \
				! -name '*.translation' \
				| sort \
				| sed "s|^|+,$VER,|" > "$MANIFEST"
		fi

		if ! git diff --quiet "$MANIFEST"; then
			CHANGED=1
		fi
		break
	fi
done

if [ "$CHANGED" -eq 1 ]; then
	git add "$MANIFEST"
	git commit -m "Update file_manifest for $TAG"
	git tag -d "$TAG"
	if [ -n "$TAG_MSG" ]; then
		git tag -a "$TAG" -m "$TAG_MSG"
	else
		git tag "$TAG"
	fi
	echo ""
	echo "=== file_manifest.txt updated, committed, and tag recreated ==="
	echo "Push again:"
	echo "  git push origin $TAG"
	exit 1
fi

exit 0
