#!/usr/bin/env bash
set -euo pipefail

GODOT_BIN="${GODOT_BIN:-godot}"
REPOSITORY_ROOT="$(git rev-parse --show-toplevel)"

if ! command -v "$GODOT_BIN" >/dev/null 2>&1; then
	echo "Error: Godot was not found in PATH."
	echo "Set GODOT_BIN to the Godot executable before pushing."
	exit 1
fi

cd "$REPOSITORY_ROOT"

echo "Running GdUnit4 tests before push..."
"$GODOT_BIN" --headless --path . -s addons/gdUnit4/bin/GdUnitCmdTool.gd \
	--ignoreHeadlessMode -a res://tests

echo "GdUnit4 tests passed."
