#!/bin/bash
## Git pre-tag hook: auto-update file_manifest.txt before tagging.
## Diffs the working tree against the last tag to find added/removed files
## in addons/gdsql/ and appends them to file_manifest.txt.

MANIFEST="addons/gdsql/tabs/plugin_updater/file_manifest.txt"
TAG="${1:-$(git describe --tags --dirty 2>/dev/null || echo 'dev')}"
VER="${TAG#v}"

PREV_TAG=$(git tag --sort=-version:refname | grep -E '^v' | sed -n '2p')

if [ -n "$PREV_TAG" ]; then
	echo "Diffing $PREV_TAG → $TAG"

	grep -v "^[+-],$VER," "$MANIFEST" > "${MANIFEST}.tmp" 2>/dev/null && mv "${MANIFEST}.tmp" "$MANIFEST"

	while IFS= read -r f; do
		[ -n "$f" ] && echo "+,$VER,$f" >> "$MANIFEST"
	done < <(git diff --name-only --diff-filter=A "$PREV_TAG"...HEAD -- addons/gdsql/)
	while IFS= read -r f; do
		[ -n "$f" ] && echo "-,$VER,$f" >> "$MANIFEST"
	done < <(git diff --name-only --diff-filter=D "$PREV_TAG"...HEAD -- addons/gdsql/)
else
	echo "No previous tag. Creating initial manifest."
	find addons/gdsql/ -type f \
		! -name '*.import' \
		! -name '*.translation' \
		| sort \
		| sed "s|^|+,$VER,|" > "$MANIFEST"
fi

git add "$MANIFEST"
