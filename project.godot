; Engine configuration file.
; It's best edited using the editor UI and not directly,
; since the parameters that go here are not all obvious.
;
; Format:
;   [section] ; section goes between []
;   param=value ; assign values to parameters

config_version=5

[animation]

compatibility/default_parent_skeleton_in_mesh_instance_3d=true

[application]

config/name="GDSQL"
config/description="GDSQL - Database SQL Workbench"
config/tags=PackedStringArray("opensource")
run/main_scene="uid://djsv3bbnpncdp"
config/features=PackedStringArray("4.7", "Forward Plus")

[debug]

gdscript/warnings/directory_rules={
"res://addons": 1,
"res://addons/gdUnit4": 0
}

[editor]

script/search_in_file_extensions=PackedStringArray("gd", "tscn", "gdshader", "cfg")

[editor_plugins]

enabled=PackedStringArray("res://addons/GDQuest_GDScript_formatter/plugin.cfg", "res://addons/ds_inspector/plugin.cfg", "res://addons/gdUnit4/plugin.cfg", "res://addons/gdsql/plugin.cfg")

[gdunit4]

settings/test/test_discovery=true
ui/toolbar/run_overall=true
hooks/session_hooks=Dictionary[String, bool]({
"res://addons/gdUnit4/src/core/hooks/GdUnitHtmlReporterTestSessionHook.gd": true,
"res://addons/gdUnit4/src/core/hooks/GdUnitXMLReporterTestSessionHook.gd": true
})
settings/test/test_lookup_folder="tests"
